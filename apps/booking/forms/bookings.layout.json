[
    {
        "type": "commandBar",
        "extraButtons": [
            {
                "name": "btnPrint",
                "caption": { "i18n": "print_invoice_btn" },
                "icon": "/apps/booking_icons/resources/public/16x16/invoice_print.png",
                "events": { "onClick": "printInvoice" }
            }
        ]
    },
    {
        "type": "tabs",
        "name": "bookingMainTabs",
        "tabs": [
            {
                "caption": { "i18n": "booking_tab_main" },
                "layout": [
                    {
                        "type": "group",
                        "caption": "",
                        "noBorder": true,
                        "orientation": "horizontal",
                        "layout": [
                            {
                                "type": "group",
                                "caption": "",
                                "noBorder": true,
                                "alignFields": true,
                                "orientation": "vertical",
                                "layout": [
                                    {
                                        "type": "textbox",
                                        "name": "number",
                                        "data": "number",
                                        "caption": { "i18n": "booking_name_field" }
                                    },
                                    {
                                        "type": "number",
                                        "name": "prepayment",
                                        "data": "prepayment",
                                        "caption": { "i18n": "prepayment_field" }
                                    },
                                    {
                                        "type": "recordSelector",
                                        "name": "clientId",
                                        "data": "clientId",
                                        "caption": { "i18n": "Client" },
                                        "properties": {
                                            "showOpenButton": true,
                                            "selection": {
                                                "table": "clients",
                                                "idField": "UID",
                                                "displayField": "name"
                                            }
                                        }
                                    }
                                ]
                            },
                            {
                                "type": "group",
                                "caption": "",
                                "noBorder": true,
                                "alignFields": true,
                                "orientation": "vertical",
                                "layout": [
                                    {
                                        "type": "date",
                                        "name": "checkIn",
                                        "data": "checkIn",
                                        "caption": { "i18n": "check_in" }
                                    },
                                    {
                                        "type": "date",
                                        "name": "checkOut",
                                        "data": "checkOut",
                                        "caption": { "i18n": "check_out" }
                                    },
                                    {
                                        "type": "recordSelector",
                                        "name": "statusId",
                                        "data": "statusId",
                                        "caption": { "i18n": "Status" },
                                        "properties": {
                                            "selection": {
                                                "table": "booking_statuses",
                                                "idField": "UID",
                                                "displayField": "name"
                                            }
                                        }
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "type": "group",
                        "caption": "",
                        "noBorder": true,
                        "orientation": "horizontal",
                        "layout": [
                            {
                                "type": "group",
                                "caption": { "i18n": "booking_rooms_tab" },
                                "noBorder": true,
                                "orientation": "vertical",
                                "layout": [{
                                    "type": "table",
                                    "name": "ts_booking_rooms",
                                    "data": "booking_rooms",
                                    "columns": [
                                        {
                                            "caption": { "i18n": "Room" },
                                            "data": "roomId",
                                            "width": 200,
                                            "inputType": "recordSelector",
                                            "properties": {
                                                "selection": { "table": "rooms", "idField": "UID", "displayField": "number" }
                                            },
                                            "events": {
                                                "onChange": "onRoomSelected"
                                            }
                                        }
                                    ],
                                    "properties": {
                                        "editMode": "cell-immediate",
                                        "visibleRows": 8,
                                        "tabularFilter": { "bookingId": "{UID}" },
                                        "masterFor":   ["ts_booking_guests", "ts_booking_room_services"],
                                        "masterField": "UID",
                                        "detailField": "bookingRoomId",
                                        "hiddenButtons": ["listSettings", "recordOpen"]
                                    }
                                }]
                            },
                            {
                                "type": "group",
                                "caption": { "i18n": "Guests" },
                                "noBorder": true,
                                "orientation": "vertical",
                                "layout": [{
                                    "type": "table",
                                    "name": "ts_booking_guests",
                                    "data": "booking_guests",
                                    "columns": [
                                        {
                                            "caption": { "i18n": "guest_type_field" },
                                            "data": "guestTypeId",
                                            "autoWidth": true,
                                            "inputType": "recordSelector",
                                            "properties": {
                                                "selection": { "table": "guest_types", "idField": "UID", "displayField": "name" }
                                            }
                                        },
                                        { "caption": { "i18n": "Quantity" }, "data": "count", "width": 110, "inputType": "integer", "defaultValue": 1, "properties": { "minValue": 0 } }
                                    ],
                                    "properties": {
                                        "editMode": "cell-immediate",
                                        "visibleRows": 8,
                                        "highlightActiveRow": false,
                                        "tabularFilter": { "bookingId": "{UID}" },
                                        "hiddenButtons": ["listSettings", "recordOpen"]
                                    }
                                }]
                            },
                            {
                                "type": "group",
                                "caption": { "i18n": "Services" },
                                "noBorder": true,
                                "orientation": "vertical",
                                "layout": [{
                                    "type": "table",
                                    "name": "ts_booking_room_services",
                                    "data": "booking_room_services",
                                    "columns": [
                                        { "caption": "✓", "data": "included", "width": 28, "inputType": "checkbox", "defaultValue": true },
                                        {
                                            "caption": { "i18n": "Service" },
                                            "data": "serviceId",
                                            "autoWidth": true,
                                            "inputType": "recordSelector",
                                            "properties": {
                                                "showSelectionButton": true,
                                                "selection": { "table": "services", "idField": "UID", "displayField": "name" }
                                            }
                                        },
                                        { "caption": "🔄", "data": "autoQuantity", "width": 28, "inputType": "checkbox", "defaultValue": true },
                                        { "caption": { "i18n": "Quantity" }, "data": "count", "width": 110, "inputType": "integer", "defaultValue": 1, "properties": { "minValue": 0 }, "events": { "onChange": "onServiceCountEdited" } }
                                    ],
                                    "properties": {
                                        "editMode": "cell-immediate",
                                        "visibleRows": 8,
                                        "highlightActiveRow": false,
                                        "tabularFilter": { "bookingId": "{UID}" },
                                        "hiddenButtons": ["listSettings", "recordOpen"]
                                    }
                                }]
                            }
                        ]
                    }
                ]
            },
            {
                "caption": { "i18n": "booking_tab_extra" },
                "layout": [
                    {
                        "type": "group",
                        "caption": "",
                        "noBorder": true,
                        "alignFields": true,
                        "orientation": "vertical",
                        "layout": [
                            {
                                "type": "recordSelector",
                                "name": "hotelId",
                                "data": "hotelId",
                                "caption": { "i18n": "Hotel" },
                                "properties": {
                                    "selection": {
                                        "table": "hotels",
                                        "idField": "UID",
                                        "displayField": "name"
                                    }
                                }
                            },
                            {
                                "type": "recordSelector",
                                "name": "organizationId",
                                "data": "organizationId",
                                "caption": { "i18n": "Organization" },
                                "properties": {
                                    "selection": {
                                        "table": "organizations",
                                        "idField": "UID",
                                        "displayField": "name"
                                    }
                                }
                            }
                        ]
                    },
                    {
                        "type": "group",
                        "caption": { "i18n": "booking_extra_lines_tab" },
                        "noBorder": true,
                        "orientation": "vertical",
                        "layout": [{
                            "type": "table",
                            "name": "ts_booking_extra_lines",
                            "data": "booking_extra_lines",
                            "columns": [
                                { "caption": { "i18n": "extra_line_name" }, "data": "name", "width": 300, "inputType": "textbox" },
                                { "caption": { "i18n": "amount_gross" }, "data": "amount", "width": 120, "inputType": "number" },
                                {
                                    "caption": { "i18n": "tax_rate" },
                                    "data": "taxRateId",
                                    "width": 120,
                                    "inputType": "recordSelector",
                                    "properties": {
                                        "selection": { "table": "tax_rates", "idField": "UID", "displayField": "name" }
                                    }
                                }
                            ],
                            "properties": {
                                "editMode": "cell-immediate",
                                "visibleRows": 5,
                                "autoPickSingleRef": false,
                                "tabularFilter": { "bookingId": "{UID}" },
                                "hiddenButtons": ["listSettings", "recordOpen"]
                            },
                            "events": {
                                "onRowActivate": "onExtraLineActivated"
                            }
                        }]
                    },
                    {
                        "type": "group",
                        "caption": { "i18n": "Notes" },
                        "noBorder": true,
                        "orientation": "vertical",
                        "layout": [
                            {
                                "type": "textarea",
                                "name": "notes",
                                "data": "notes",
                                "caption": ""
                            }
                        ]
                    }
                ]
            }
        ]
    }
]
