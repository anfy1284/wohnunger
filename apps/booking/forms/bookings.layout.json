[
    {
        "type": "group",
        "caption": { "i18n": "Booking" },
        "orientation": "horizontal",
        "layout": [
            {
                "type": "group",
                "caption": "",
                "orientation": "vertical",
                "layout": [
                    {
                        "type": "textbox",
                        "name": "name",
                        "data": "name",
                        "caption": { "i18n": "booking_name_field" }
                    },
                    {
                        "type": "number",
                        "name": "prepayment",
                        "data": "prepayment",
                        "caption": { "i18n": "prepayment_field" }
                    },
                    {
                        "type": "recordSelector",
                        "name": "clientId",
                        "data": "clientId",
                        "caption": { "i18n": "Client" },
                        "properties": {
                            "showSelectionButton": true,
                            "selection": {
                                "table": "clients",
                                "idField": "UID",
                                "displayField": "name"
                            }
                        }
                    },
                    {
                        "type": "recordSelector",
                        "name": "hotelId",
                        "data": "hotelId",
                        "caption": { "i18n": "Hotel" },
                        "properties": {
                            "showSelectionButton": true,
                            "selection": {
                                "table": "hotels",
                                "idField": "UID",
                                "displayField": "name"
                            }
                        }
                    },
                    {
                        "type": "recordSelector",
                        "name": "organizationId",
                        "data": "organizationId",
                        "caption": { "i18n": "Organization" },
                        "properties": {
                            "showSelectionButton": true,
                            "selection": {
                                "table": "organizations",
                                "idField": "UID",
                                "displayField": "name"
                            }
                        }
                    }
                ]
            },
            {
                "type": "group",
                "caption": "",
                "orientation": "vertical",
                "layout": [
                    {
                        "type": "date",
                        "name": "checkIn",
                        "data": "checkIn",
                        "caption": { "i18n": "check_in" }
                    },
                    {
                        "type": "date",
                        "name": "checkOut",
                        "data": "checkOut",
                        "caption": { "i18n": "check_out" }
                    },
                    {
                        "type": "emunList",
                        "name": "status",
                        "data": "status",
                        "caption": { "i18n": "Status" },
                        "options": [
                            { "value": "draft",      "caption": { "i18n": "Draft" } },
                            { "value": "confirmed",  "caption": { "i18n": "Confirmed" } },
                            { "value": "checkedIn",  "caption": { "i18n": "check_in" } },
                            { "value": "checkedOut", "caption": { "i18n": "check_out" } },
                            { "value": "cancelled",  "caption": { "i18n": "Cancelled" } }
                        ]
                    }
                ]
            }
        ]
    },
    {
        "type": "group",
        "caption": "",
        "orientation": "horizontal",
        "layout": [
            {
                "type": "group",
                "caption": { "i18n": "booking_rooms_tab" },
                "orientation": "vertical",
                "layout": [{
                    "type": "table",
                    "name": "ts_booking_rooms",
                    "data": "booking_rooms",
                    "columns": [
                        {
                            "caption": { "i18n": "Room" },
                            "data": "roomId",
                            "width": 200,
                            "inputType": "recordSelector",
                            "properties": {
                                "showSelectionButton": true,
                                "selection": { "table": "rooms", "idField": "UID", "displayField": "number" }
                            }
                        }
                    ],
                    "properties": {
                        "editMode": "cell-immediate",
                        "visibleRows": 8,
                        "tabularFilter": { "bookingId": "{UID}" },
                        "masterFor":   ["ts_booking_guests", "ts_booking_room_services"],
                        "masterField": "UID",
                        "detailField": "bookingRoomId",
                        "hiddenButtons": ["listSettings", "recordOpen"]
                    },
                    "events": {
                        "onRowActivate": "onRoomActivated"
                    }
                }]
            },
            {
                "type": "group",
                "caption": { "i18n": "Guests" },
                "orientation": "vertical",
                "layout": [{
                    "type": "table",
                    "name": "ts_booking_guests",
                    "data": "booking_guests",
                    "columns": [
                        {
                            "caption": { "i18n": "guest_type_field" },
                            "data": "guestTypeId",
                            "width": 180,
                            "inputType": "recordSelector",
                            "properties": {
                                "showSelectionButton": true,
                                "selection": { "table": "guest_types", "idField": "UID", "displayField": "name" }
                            }
                        },
                        { "caption": { "i18n": "Quantity" }, "data": "count", "width": 80, "inputType": "number" }
                    ],
                    "properties": {
                        "editMode": "cell-immediate",
                        "visibleRows": 8,
                        "tabularFilter": { "bookingId": "{UID}" },
                        "hiddenButtons": ["listSettings", "recordOpen"]
                    }
                }]
            },
            {
                "type": "group",
                "caption": { "i18n": "Services" },
                "orientation": "vertical",
                "layout": [{
                    "type": "table",
                    "name": "ts_booking_room_services",
                    "data": "booking_room_services",
                    "columns": [
                        {
                            "caption": { "i18n": "Service" },
                            "data": "serviceId",
                            "width": 200,
                            "readOnly": true,
                            "inputType": "recordSelector",
                            "properties": {
                                "showSelectionButton": true,
                                "selection": { "table": "services", "idField": "UID", "displayField": "name" }
                            }
                        },
                        { "caption": { "i18n": "Included" }, "data": "count", "width": 60, "inputType": "checkbox" }
                    ],
                    "properties": {
                        "editMode": "cell-immediate",
                        "visibleRows": 8,
                        "tabularFilter": { "bookingId": "{UID}" },
                        "hiddenButtons": ["listSettings", "recordOpen"]
                    }
                }]
            }
        ]
    },
    {
        "type": "group",
        "caption": { "i18n": "Notes" },
        "orientation": "vertical",
        "layout": [
            {
                "type": "textarea",
                "name": "notes",
                "data": "notes",
                "caption": ""
            }
        ]
    },
    {
        "type": "group",
        "caption": "",
        "orientation": "horizontal",
        "layout": [
            { "type": "button", "action": "save",    "caption": { "i18n": "Save" },           "icon": "/apps/general_icons/resources/public/16x16/save.png" },
            { "type": "button", "action": "cancel",  "caption": { "i18n": "Cancel" },              "icon": "/apps/general_icons/resources/public/16x16/cancel.png" },
            { "type": "button", "name": "btnPrint",  "caption": { "i18n": "print_invoice_btn" },         "icon": "/apps/booking_icons/resources/public/16x16/invoice_print.png",
              "events": { "onClick": "printInvoice" } }
        ]
    }
]
